{
  "name": "comphp/config",
  "type": "library",
  "description": "Configuration loading, organization, and access for PHP applications.",
  "license": "MIT",
  "version": "0.3",
  "autoload": {
    "psr-4": {
      "CommonPHP\\Config\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CommonPHP\\Config\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.5",
    "psr/container": "^2.0",
    "psr/log": "^3.0",
    "comphp/runtime": "^0.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "friendsofphp/php-cs-fixer": "^3.95"
  }
}